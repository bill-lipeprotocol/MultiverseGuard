# MultiverseGuard environment configuration.
# Copy to .env and fill in real values. Never commit .env or real keys.

# Primary model: Cerebras Gemma 4 31B
CEREBRAS_API_KEY=your_cerebras_key_here
CEREBRAS_MODEL=gemma-4-31b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_REASONING_EFFORT=low

# Set to false for live Cerebras calls; keep true for mock-mode rehearsal.
MULTIVERSEGUARD_MOCK=true

# Benchmark comparison provider (optional): Together AI GLM-5.2
TOGETHER_API_KEY=your_together_key_here
TOGETHER_BASE_URL=https://api.together.ai/v1
TOGETHER_MODEL=zai-org/GLM-5.2

# Optional: gate live calls on a public deployment.
# If set, the hosted app requires this code before live Cerebras/Together calls.
# Leave blank for normal local development.
APP_ACCESS_CODE=